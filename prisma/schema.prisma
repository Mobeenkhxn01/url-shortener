generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Url{
  id        Int      @id @default(autoincrement())
  original  String   
  short     String   @unique
  visits   Int      @default(0)
  createdAt DateTime @default(now())
  sessionId String?
}
